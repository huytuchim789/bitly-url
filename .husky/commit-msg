#!/bin/sh

set -e

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Strip comments
commit_msg=$(echo "$commit_msg" | head -1)

# Regex pattern
pattern="^(feat|fix|refactor|chore|docs|style|test|perf|ci)\([a-z0-9_-]+\): .{1,72}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "============================================"
  echo "  Invalid commit message format!"
  echo ""
  echo "  Expected: type(scope): description"
  echo "  Example:  feat(server): add health check"
  echo ""
  echo "  Types: feat|fix|refactor|chore|docs|style|test|perf|ci"
  echo "============================================"
  echo ""
  exit 1
fi
